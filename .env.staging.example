# Docker Compose interpolation variables for staging.
VITE_TELEGRAM_BOT_USERNAME=ClientFRP_bot
VITE_BRAND_SUPPORT_TG=@frpnnow
VITE_SITE_URL=https://staging.frpclient.ru
FRONTEND_PORT_BIND=127.0.0.1:18081:80

BACKEND_ENV_FILE=./backend/.env.staging
BACKEND_SECRETS_FILE=/etc/frpclient/backend.staging.secrets.env
FRONTEND_BUILD_SECRETS_FILE=/etc/frpclient/frontend.staging.build.secrets.env

COMPOSE_PROJECT_NAME=frpclient-staging
RUNTIME_STATE_DIR=./.deploy.staging
POSTGRES_CONTAINER_NAME=frp-staging-postgres
REDIS_CONTAINER_NAME=frp-staging-redis
BACKEND_CONTAINER_NAME=frp-staging-backend
BACKEND_WS_CONTAINER_NAME=frp-staging-backend-ws
FRONTEND_CONTAINER_NAME=frp-staging-frontend
TELEGRAM_BOT_CONTAINER_NAME=frp-staging-telegram-bot
POSTGRES_VOLUME_NAME=frpclient_staging_postgres_data
BACKEND_MEDIA_VOLUME_NAME=frpclient_staging_backend_media
BACKEND_STATIC_VOLUME_NAME=frpclient_staging_backend_static
