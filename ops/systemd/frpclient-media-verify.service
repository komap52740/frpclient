[Unit]
Description=FRP Client media backup verification
Wants=network-online.target
After=network-online.target frpclient-media-backup.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/FRPclient
Environment=BACKUP_DIR=/var/backups/frpclient/media
Environment=VERIFY_ROOT=/tmp/frpclient_media_verify
ExecStart=/bin/sh /var/www/FRPclient/ops/backup/media_verify_backup.sh
