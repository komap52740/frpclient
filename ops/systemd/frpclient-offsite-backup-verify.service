[Unit]
Description=FRP Client offsite backup verification
Wants=network-online.target
After=network-online.target frpclient-postgres-backup.service frpclient-media-backup.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/FRPclient
Environment=PROJECT_DIR=/var/www/FRPclient
Environment=BACKUP_DIR=/var/backups/frpclient/postgres
Environment=MEDIA_BACKUP_DIR=/var/backups/frpclient/media
ExecStart=/bin/sh /var/www/FRPclient/ops/backup/offsite_verify_backup.sh
