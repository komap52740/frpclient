# Переменные интерполяции docker compose (корень проекта)
# Используются в docker-compose.prod.yml во время build frontend.

# Имя Telegram-бота для Telegram Login Widget на фронте
VITE_TELEGRAM_BOT_USERNAME=ClientFRP_bot
VITE_BRAND_SUPPORT_TG=@frpnnow

# Порт, на который публикуется frontend-контейнер (для system nginx proxy)
FRONTEND_PORT_BIND=127.0.0.1:8080:80
VITE_SITE_URL=https://frpclient.ru
BACKEND_ENV_FILE=./backend/.env
BACKEND_SECRETS_FILE=/etc/frpclient/backend.secrets.env
FRONTEND_BUILD_SECRETS_FILE=/etc/frpclient/frontend.build.secrets.env
